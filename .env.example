# === PROJECT ATLAS — Environment Configuration ===
# Copy this file to .env and fill in your keys

# ── LLM Keys (Priority: Claude → Gemini → Deterministic Fallback) ──────────
# Primary: Claude Sonnet via Anthropic SDK
# Get free key at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Fallback: Gemini 2.5 Flash via Google AI Studio (OpenAI-compat endpoint)
# Get free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Model Names ──────────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-5
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# ── Embedding Model ───────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Data Paths (relative to project-atlas/) ──────────────────────────────────
DATA_PATH=data/Coursera.csv
REVIEWS_PATH=data/reviews.csv
REVIEWS_BY_COURSE_PATH=data/reviews_by_course.csv

# ── Index Storage (LangChain FAISS uses a directory) ──────────────────────────
FAISS_INDEX_DIR=indexes/faiss_store

# ── Retrieval Settings ────────────────────────────────────────────────────────
TOP_K_RETRIEVAL=15
MAX_REVIEWS_PER_COURSE=3

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
